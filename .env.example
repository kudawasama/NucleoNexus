# Nucleo Nexus - Ejemplo de Variables de Entorno
# ===============================================
# Copia este archivo como .env y completa los valores.
# El .env esta en .gitignore, no se subira a git.
#
#   cp .env.example .env

# Token de GitHub para operaciones git automaticas
# Crea uno en: GitHub > Settings > Developer settings > Personal access tokens
# Permisos minimos: repo (push/pull)
GITHUB_TOKEN=

# API Key para OpenCode (opcional)
# Solo si usas backend opencode en lugar de Ollama
OPENCODE_GO_API_KEY=

# Token para autenticacion en la API REST de Nexus
# Se usa en el header Authorization: Bearer <token>
NEXUS_API_TOKEN=nexus_secret_key_2026
